# Copy to .env.worker and fill in the real host, database, credentials. .env.worker is gitignored.
# Used by docker compose (env_file) to supply the Worker service's runtime configuration.
ConnectionStrings__GauDB=Host=your-db-host;Port=5432;Database=your-db;Username=your-user;Password=CHANGEME;SSL Mode=Require

# Hangfire dashboard login (OIDC, confidential client) — requires the "Hangfire" realm role
Authentication__Authority=https://your-provider/realms/your-realm
Authentication__ClientId=your-worker-dashboard-client
Authentication__ClientSecret=CHANGEME
Authentication__RequireHttpsMetadata=true
