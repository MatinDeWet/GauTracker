# Copy to .env.api and fill in the real host, database, credentials. .env.api is gitignored.
# Used by docker compose (env_file) to supply the WebApi service's runtime configuration.
ConnectionStrings__GauDB=Host=your-db-host;Port=5432;Database=your-db;Username=your-user;Password=CHANGEME;SSL Mode=Require

# Identity provider (OIDC) — bearer auth for the API + Swagger login
Authentication__Authority=https://your-provider/realms/your-realm
Authentication__Audience=your-api-audience
Authentication__Swagger__ClientId=your-swagger-client
Authentication__Swagger__AuthorizationUrl=https://your-provider/realms/your-realm/protocol/openid-connect/auth
Authentication__Swagger__TokenUrl=https://your-provider/realms/your-realm/protocol/openid-connect/token

# Blob storage (S3-compatible)
BlobStorage__ServiceUrl=https://your-s3-endpoint
BlobStorage__AccessKey=CHANGEME
BlobStorage__SecretKey=CHANGEME
BlobStorage__Region=us-east-1
