{
  "ConnectionStrings": {
    "GauDB": ""
  },
  "Authentication": {
    "Authority": "https://localhost:8443/realms/gautracker",
    "Audience": "gautracker-api",
    "RequireHttpsMetadata": true,
    "ValidateAudience": true,
    "Swagger": {
      "ClientId": "gautracker-swagger",
      "AuthorizationUrl": "https://localhost:8443/realms/gautracker/protocol/openid-connect/auth",
      "TokenUrl": "https://localhost:8443/realms/gautracker/protocol/openid-connect/token",
      "Scopes": {
        "openid": "OpenID",
        "profile": "User profile"
      }
    }
  },
  "Cache": {
    "DefaultExpiration": "00:05:00",
    "MaximumEntrySize": 1048576
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
